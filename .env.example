# ========================
# Dingwall Homelab - Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the .env file
# ========================

# General
TZ=America/Chicago
PUID=1000
PGID=1000

# Paths
MEDIA_PATH=/path/to/media
DOWNLOADS_PATH=/path/to/downloads
CONFIG_PATH=/path/to/configs

# VPN (Gluetun)
VPN_SERVICE_PROVIDER=your_provider
WIREGUARD_PRIVATE_KEY=your_wireguard_private_key
WIREGUARD_PRESHARED_KEY=your_wireguard_preshared_key

# Cloudflare
CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token

# Immich / Postgres
DB_PASSWORD=change_me

# Seafile
SEAFILE_MYSQL_ROOT_PASSWORD=change_me
SEAFILE_ADMIN_PASSWORD=change_me

# Bonob / Navidrome
BNB_SECRET=change_me

# Jellyfin
JELLYFIN_PORT=8096

# qBittorrent
QBIT_WEBUI_PORT=8080

# Arr Stack
RADARR_PORT=7878
SONARR_PORT=8989
LIDARR_PORT=8686
JACKETT_PORT=9117

# Home Assistant
HA_PORT=8123

# PostgreSQL Central
# Password managed via Docker secrets (see secrets/ directory)
# POSTGRES_PASSWORD_FILE=/run/secrets/postgres_central_password

# pgAdmin
# Password managed via Docker secrets (see secrets/ directory)
# PGADMIN_DEFAULT_PASSWORD_FILE=/run/secrets/pgadmin_password
